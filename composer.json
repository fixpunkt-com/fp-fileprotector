{
  "name": "fixpunkt/fp-fileprotector",
  "type": "typo3-cms-extension",
  "description": "File Protector",
  "minimum-stability": "stable",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "fixpunkt für digitales GmbH",
      "email": "office@fixpunkt.com",
      "homepage": "https://fixpunkt.com",
      "role": "Company"
    },
    {
      "name": "Yannik Börgener",
      "role": "Developer"
    },
    {
      "name": "David Schneider",
      "role": "Developer"
    },
    {
      "name": "Mohamad Sulaiman",
      "role": "Developer"
    }
  ],
  "require": {
    "typo3/cms-core": "^13 || ^12",
    "php": "^8.2"
  },
  "require-dev": {
    "typo3/coding-standards": "*",
    "typo3/tailor": "^1.7"
  },
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpFileprotector\\": "Classes"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "fp_fileprotector"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  }
}
